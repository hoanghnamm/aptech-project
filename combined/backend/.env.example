# Server
PORT=5000
NODE_ENV=development

# Frontend origin for CORS (the Vite dev server)
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/pawintel

# Auth
JWT_SECRET=change-me-in-production

# Groq AI (chatbot / nutrition / recommendation)
GROQ_API_KEY=your-groq-api-key
# Use a model that supports structured outputs (json_schema)
GROQ_MODEL=openai/gpt-oss-20b

# Python AI microservice (dog breed recognition model)
PYTHON_AI_SERVICE_URL=http://localhost:8000/predict
